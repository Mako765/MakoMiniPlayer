<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#1A0A2E"
    android:padding="40dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="M"
        android:textColor="#00FF88"
        android:textSize="120sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mako Mini Player"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:layout_marginBottom="60dp" />

    <Button
        android:id="@+id/btn_open_video"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="📂  Open Video File"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3D1A6E"
        android:focusable="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="or launch from Tivi Mate / Stremio / IPTV app"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp" />

    <!-- Recent Files -->
    <TextView
        android:id="@+id/tv_recent_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent"
        android:textColor="#00FF88"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/recent_files_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal" />

</LinearLayout>